<Window x:Class="P20260311_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:P20260311_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>

        <Label Content="Tanulói nyílvántartó rendszer" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <Button x:Name="belep" Content="Belépés" Width="80" Height="40" Grid.Row="2" Grid.Column="2" Click="belep_Click" VerticalAlignment="Top" Margin="0 10 0 0"/>
        <Button x:Name="kilep" Content="Kilépés" Width="80" Height="40" Grid.Row="2" Grid.Column="2" Click="kilep_Click" VerticalAlignment="Top" Margin="0 260 0 0"/>
        <Button x:Name="regisztral" Content="Regisztráció" Width="80" Height="40" Grid.Row="2" Grid.Column="2" Click="regisztral_Click" VerticalAlignment="Top" Margin="0 60 0 0"/>

    </Grid>
</Window>
