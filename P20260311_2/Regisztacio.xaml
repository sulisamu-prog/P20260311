<Window x:Class="P20260311_2.Regisztacio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:P20260311_2"
        mc:Ignorable="d"
        Title="Regisztacio" Height="450" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>

        <Label Content="Jelentkezés" Grid.Row="1" Grid.Column="1" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <Label Content="Név:" Grid.Row="2" Grid.Column="1" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <TextBox x:Name="nev" Grid.Row="3" Grid.Column="1" Width="150" Height="25" VerticalAlignment="Top"/>
        <Label Content="Ágazat:" Grid.Row="4" Grid.Column="1" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        <ComboBox x:Name="agazat" Grid.Row="5" Grid.Column="1" Width="150" Height="25">
            <ComboBoxItem x:Name="infoTag" Content="Informatika"></ComboBoxItem>
            <ComboBoxItem x:Name="euTag" Content="Egészségügy"></ComboBoxItem>
            <ComboBoxItem x:Name="pedTag" Content="Pedagógia"></ComboBoxItem>
        </ComboBox>
        <Button x:Name="jelentkez" Content="Jelentkezés" Grid.Row="6" Grid.Column="1" Width="160" Height="40" Click="jelentkez_Click"/>
    </Grid>
</Window>
